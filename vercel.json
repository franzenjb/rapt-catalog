{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "rcrapt\\.jbf\\.com" }],
      "destination": "/redcross.html"
    }
  ],
  "headers": [
    { "source": "/(.*)", "headers": [{ "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }] }
  ]
}
